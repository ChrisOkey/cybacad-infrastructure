{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Folder structure
    "rootDir": "src",
    "outDir": "dist",

    // Emit declarations for shared types
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // ESM + Zod compatibility
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",

    // Runtime safety
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Disable conflicting option from base config
    "allowImportingTsExtensions": false
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}

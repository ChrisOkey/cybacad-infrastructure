{
  "name": "cybacad-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo 'Use dev:frontend or dev:backend instead'",
    "dev:backend": "pnpm --filter cybacad-backend-api dev",
    "dev:frontend": "pnpm --filter cybacad-frontend-web dev",
    "build": "pnpm build:frontend && pnpm build:backend",
    "build:frontend": "pnpm --filter cybacad-frontend-web build",
    "build:backend": "pnpm --filter cybacad-backend-api build",
    "lint": "pnpm --filter cybacad-frontend-web lint",
    "build:shared-types": "pnpm --filter shared-types run build",
    "typecheck:shared-types": "pnpm --filter shared-types run typecheck",
    
    
    "generate:openapi": "pnpm exec tsx generate-openapi.ts", 
    
    "dev:openapi": "pnpm run typecheck:shared-types && pnpm run build:shared-types && pnpm run generate:openapi",
    "watch:openapi": "nodemon --watch packages/shared-types/src --exec \"pnpm run dev:openapi\""
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "tsx": "^4.20.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  }
}
